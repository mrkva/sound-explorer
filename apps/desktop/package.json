{
  "name": "field-recording-explorer",
  "version": "0.2.4",
  "description": "High-resolution spectrogram viewer with BWF timecode navigation for field recordings",
  "main": "main.js",
  "scripts": {
    "start": "npm run prebuild && electron .",
    "pack": "electron-builder --dir",
    "clean": "rm -rf dist",
    "predist": "npm run clean",
    "prebuild": "mkdir -p lib && cp ../../lib/*.js lib/",
    "dist": "npm run prebuild && electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.fieldrecording.explorer",
    "productName": "Field Recording Explorer",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "src/**/*",
      "styles/**/*",
      "lib/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "wav",
        "name": "WAV Audio",
        "description": "WAV Audio File",
        "mimeType": "audio/wav"
      }
    ],
    "mac": {
      "category": "public.app-category.music"
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "win": {
      "target": ["nsis", "portable"]
    }
  }
}
