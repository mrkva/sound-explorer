{
  "name": "sound-explorer",
  "version": "0.3.0",
  "description": "Spectrogram viewer and audio explorer for field recordings and ultrasonics",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "clean": "rm -rf dist",
    "predist": "npm run clean",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.soundexplorer.app",
    "productName": "Sound Explorer",
    "icon": "icon.png",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "src/**/*",
      "styles/**/*",
      "icon.png"
    ],
    "fileAssociations": [
      {
        "ext": "wav",
        "name": "WAV Audio",
        "description": "WAV Audio File",
        "mimeType": "audio/wav"
      }
    ],
    "mac": {
      "category": "public.app-category.music"
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "win": {
      "target": ["nsis", "portable"]
    }
  }
}
